{
  "compatibility_date": "2025-06-01",
  "main": "src/index.ts",
  "name": "aireclast",
  "upload_source_maps": true,
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "kv_namespaces": [
    {
      "binding": "AUTH_STORE",
      "id": "YOUR_KV_NAMESPACE_ID"
    }
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "src/static"
  }
}
